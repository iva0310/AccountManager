<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wake_up.PrivateOrPublic">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="10">

            <Label
                Text=""/>

            <Button
                Text="Public" 
                Clicked="PublicAccClicked"
                HorizontalOptions="Fill" FontSize="Medium" />

            <Button
                Text="Private" 
                Clicked="PrivateAccClicked"
                HorizontalOptions="Fill" FontSize="Medium" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>