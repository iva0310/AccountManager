<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wake_up.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="10">
            <Label/>
            <Label/>
            <Image
                x:Name="MainPageImage"
                Source="kawi.gif"
                IsAnimationPlaying="True"
                HeightRequest="185"
                Aspect="AspectFit"/>

            <Label
                Text="Account Manager"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Button
                Text="Add an Account" 
                Clicked="AddAccountButtonClicked"
                HorizontalOptions="Center">

                <VisualStateManager.VisualStateGroups>
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="Pink" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </VisualStateManager.VisualStateGroups>
            </Button>

            <Button
                Text="Account Manager"
                Clicked="PublicOrPrivateClicked"
                HorizontalOptions="Center" FontSize="20">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="Pink" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </VisualStateManager.VisualStateGroups>
            </Button>
            <Grid>
                <ImageButton
                    Source="setting.jpg" 
                    WidthRequest="10"
                    HeightRequest="10"
                    Margin="25" 
                    HorizontalOptions="End"
                    VerticalOptions="End" BackgroundColor="#00000000"
                    ToolTipProperties.Text="Setting"
                    Clicked="SettingClicked"
                />
            </Grid>




        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
